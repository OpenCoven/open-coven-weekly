{
  "name": "@opencoven/open-coven-weekly",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "node scripts/slidev-current.mjs dev --open",
    "build": "node scripts/slidev-current.mjs build --base /open-coven-weekly/",
    "build:vercel": "node scripts/slidev-current.mjs build --base /",
    "export": "node scripts/slidev-current.mjs export --format pdf",
    "test": "node --test scripts/*.test.mjs",
    "verify:dist": "node scripts/verify-dist.mjs",
    "verify": "pnpm test && node scripts/verify-week.mjs && pnpm build && pnpm build:vercel && pnpm verify:dist",
    "new": "node scripts/new-week.mjs"
  },
  "dependencies": {
    "@slidev/cli": "52.15.2",
    "@slidev/theme-default": "0.25.0",
    "vue": "3.5.34"
  },
  "devDependencies": {
    "vite": "7.3.3"
  }
}
